generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentFetchStatus {
  queued
  fetched
  failed
}

enum DistillationStatus {
  draft
  published
  failed
}

enum EventType {
  chapter_completed
  book_completed
  streak_updated
  badge_claimed
}

enum BadgeCode {
  first_book
  seven_day_streak
  thirty_chapters
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  timezone         String
  booksPerYearGoal Int
  paceMinutesPerDay Int
  xp               Int                @default(0)
  streakCount      Int                @default(0)
  lastStreakAt     DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  assignments      DailyAssignment[]
  progress         ReadingProgress[]
  events           GamificationEvent[]
  badges           BadgeAward[]
}

model BookSource {
  id         String           @id @default(cuid())
  sourceUrl  String
  titleHint  String?
  authorHint String?
  checksum   String?
  fetchStatus ContentFetchStatus
  createdAt  DateTime         @default(now())
}

model Book {
  id                    String            @id @default(cuid())
  title                 String
  author                String
  coverUrl              String?
  totalEstimatedMinutes Int
  createdAt             DateTime          @default(now())
  distillations         Distillation[]
  assignments           DailyAssignment[]
  progress              ReadingProgress[]
}

model Distillation {
  id                    String            @id @default(cuid())
  bookId                String
  version               Int
  bookSummary           String
  contextThreads        String[]
  totalEstimatedMinutes Int
  status                DistillationStatus
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  book                  Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapters              DistilledChapter[]

  @@unique([bookId, version])
}

model DistilledChapter {
  id                  String       @id @default(cuid())
  distillationId      String
  chapterNumber       Int
  title               String
  summary             String
  contextWhyItMatters String
  estimatedMinutes    Int
  sourceSpanRefs      String[]
  distillation        Distillation @relation(fields: [distillationId], references: [id], onDelete: Cascade)

  @@unique([distillationId, chapterNumber])
}

model DailyAssignment {
  id         String   @id @default(cuid())
  userId     String
  bookId     String
  assignedAt DateTime
  locked     Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId, locked])
}

model ReadingProgress {
  id                  String   @id @default(cuid())
  userId              String
  bookId              String
  currentChapter      Int
  completedChapterIds String[]
  readingSeconds      Int      @default(0)
  completed           Boolean  @default(false)
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book                Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model GamificationEvent {
  id        String   @id @default(cuid())
  userId    String
  type      EventType
  deltaXp   Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model BadgeAward {
  id        String    @id @default(cuid())
  userId    String
  badgeCode BadgeCode
  claimed   Boolean   @default(false)
  earnedAt  DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeCode])
}
